# =============================================================================
# FILE:    .env.example
# PURPOSE: Template for the local runtime environment file.
#          Copy this to .env and fill in values for your machine before
#          running any training job that should publish to MLflow.
# USAGE:   cp .env.example .env
# WHEN:    Do this once when you clone the repository.
# PREREQS: MLflow server must be running for mlflow_candidate_review mode.
#          Start it with: bash training-control-plane/start-mlflow-server.sh
# OUTPUT:  .env is read automatically by Pydantic Settings when the pipeline
#          runs from the ml-training/ directory.
# =============================================================================
#
# ENTERPRISE EQUIVALENT:
#   This file is the documented interface contract between a developer's machine
#   and the pipeline. In Kubernetes, the same variables are injected from a
#   ConfigMap/Secret. This template tells any new team member exactly which
#   variables exist, what they do, and what value to use for local development.
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Section 1: Base pipeline paths
# ─────────────────────────────────────────────────────────────────────────────
PIPELINE_CONFIG_PATH=configs/training_pipeline.yaml
ARTIFACT_STORE_ROOT=artifacts
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
# Section 2: Hyperparameter search runtime knobs
# ─────────────────────────────────────────────────────────────────────────────
OPTUNA_N_TRIALS=5
RANDOM_SEED=42

# ─────────────────────────────────────────────────────────────────────────────
# Section 3: Runtime mode and MLflow registry handoff
# Change TRAINING_TRIGGERED_BY to your own name before running.
# ─────────────────────────────────────────────────────────────────────────────
TRAINING_RUNTIME_MODE=mlflow_candidate_review
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
# Optional per-run override. Leave blank to use experiment_name from
# configs/training_pipeline.yaml.
# ENTERPRISE EMPHASIS: This lets one teammate recover from a deleted or retired
# experiment name without editing the shared team ConfigMap source.
MLFLOW_EXPERIMENT_NAME=
# What to do if the requested experiment exists only in MLflow's deleted state:
#   restore -> bring it back automatically and keep lineage intact
#   fail    -> stop early and force the user to choose a new name or restore it
MLFLOW_DELETED_EXPERIMENT_POLICY=restore
MLFLOW_REGISTERED_MODEL_NAME=wine-quality-classifier
MLFLOW_CANDIDATE_ALIAS=candidate

# ─────────────────────────────────────────────────────────────────────────────
# Section 4: Human/automation audit metadata
# Replace <your-name> and describe what this specific run is for.
# ─────────────────────────────────────────────────────────────────────────────
TRAINING_TRIGGERED_BY=<your-name>
TRAINING_RUN_REASON=<why you are running training today>
