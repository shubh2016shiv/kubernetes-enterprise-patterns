# =============================================================================
# FILE:    configs/local-mlflow.env.example
# PURPOSE: Local WSL2 training runtime settings for publishing candidate runs
#          to the local MLflow server.
# USAGE:   cp configs/local-mlflow.env.example configs/local-mlflow.env
# WHEN:    Use before running a teammate-style candidate training run.
# PREREQS: MLflow server running at http://127.0.0.1:5000.
# OUTPUT:  The training pipeline logs Optuna trials to MLflow and registers a
#          passing final model as the `candidate` model version.
# =============================================================================

# Stage 1.0 - Base pipeline paths.
# Why: The Python package has safe defaults, but the env file makes the runtime
# contract visible to learners and mirrors a Kubernetes ConfigMap.
PIPELINE_CONFIG_PATH=configs/training_pipeline.yaml
ARTIFACT_STORE_ROOT=artifacts
LOG_LEVEL=INFO

# Stage 2.0 - Hyperparameter search runtime knobs.
# Why: Team members may need to rerun training with a smaller smoke-test search
# or a larger candidate search without changing Python code.
OPTUNA_N_TRIALS=5
RANDOM_SEED=42

# Stage 3.0 - Runtime mode and MLflow registry handoff.
# Why: In enterprise, the platform declares what kind of run this is. A local
# artifact-only run is useful for developer smoke tests. A candidate-review run
# must publish experiment evidence and a reviewable model version to MLflow.
TRAINING_RUNTIME_MODE=mlflow_candidate_review
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
MLFLOW_REGISTERED_MODEL_NAME=wine-quality-classifier
MLFLOW_CANDIDATE_ALIAS=candidate

# Stage 4.0 - Human/automation audit metadata.
# Why: In a multi-member team, reviewers must know who requested a run and why.
TRAINING_TRIGGERED_BY=shubham
TRAINING_RUN_REASON=manual candidate run from local lab
