# =============================================================================
# FILE:    02-inference-configmap.yaml
# KIND:    ConfigMap
# PURPOSE: Provide non-sensitive runtime configuration to the inference API pod.
#          The most important fields — MODEL_URI and MODEL_VERSION — are set by
#          the CI/CD release bridge after resolving the MLflow @champion alias.
# WHEN:    ml-inferencing module — apply before the Deployment, or re-apply
#          when the release bridge updates the model reference.
# ENTERPRISE EQUIVALENT: In Helm-based deployments, these values would live in
#   values.yaml per environment overlay. In Kustomize, they would be in
#   kustomization.yaml patches. In ArgoCD, they would be ApplicationSet
#   parameters. The ConfigMap itself is the Kubernetes primitive that carries
#   the values regardless of which tool generated it.
# =============================================================================

# IMPORTANT: MODEL_URI and MODEL_VERSION below are placeholders.
# Before applying the Deployment, run the release bridge to resolve the
# @champion alias and update these values:
#
#   cd release-bridge/
#   ./resolve-approved-model-reference.sh
#   ./render-inference-config.sh
#   ./rollout-approved-model.sh
#
# After the bridge runs, MODEL_URI will contain the immutable version URI such as:
#   models:/wine-quality-classifier-prod/1
#
# ENTERPRISE EMPHASIS: Never point MODEL_URI at a moving alias such as
# @champion. FastAPI loads the model at pod startup. An alias can be reassigned
# by a manager after pods start — existing pods would then serve a different
# model version than what @champion points to. Pinning to an immutable version
# number makes deployed behavior auditable and rollback deterministic.

apiVersion: v1
kind: ConfigMap
metadata:
  # CAN BE CHANGED: Rename the ConfigMap if you want a different application
  # config object, for example `fraud-inference-config`. If changed, update the
  # Deployment `envFrom.configMapRef.name` and every script that reads this name.
  name: wine-quality-inference-config
  # CAN BE CHANGED: Namespace must match 01-namespace.yaml. Example:
  # `namespace: ml-inference-dev` when the namespace name is changed there.
  namespace: ml-inference
  labels:
    app.kubernetes.io/name: wine-quality-inference-api
    app.kubernetes.io/component: inference
    app.kubernetes.io/part-of: k8s-mlops-platform
    app.kubernetes.io/managed-by: kubectl

  annotations:
    # CAN BE CHANGED: The release approval alias can be `champion`, `staging`,
    # or another MLflow alias your team uses. Example: `"production-approved"`.
    #
    # Record which MLflow alias was resolved to produce these values.
    # The release bridge writes this annotation so the ConfigMap history shows
    # how each deployed version was chosen.
    # Update this when the release bridge runs.
    mlops.platform/resolved-from-alias: "champion"

    # Record when this ConfigMap was last updated by the release bridge.
    # Useful for on-call investigations: "when was this model last deployed?"
    # Update this when the release bridge runs.
    mlops.platform/last-updated: "2026-04-25T18:09:28Z"

data:
  # ─────────────────────────────────────────────────────────────────────────
  # Model reference fields — set by the CI/CD release bridge.
  # These are the values the release bridge writes after resolving @champion.
  # ─────────────────────────────────────────────────────────────────────────

  # The immutable MLflow model URI for this deployment.
  # Format: models:/<registered-model-name>/<version-number>
  # The release bridge resolves @champion to a version number and writes this.
  # Example after release: models:/wine-quality-classifier-prod/1
  # CAN BE CHANGED: Set this to the exact MLflow model version you want to
  # deploy. Example: `models:/fraud-risk-classifier-prod/7`.
  MODEL_URI: "models:/wine-quality-classifier-prod/1"

  # Human-readable version number, extracted from MODEL_URI.
  # Used in logs, health check responses, and Prometheus metrics labels.
  # Example after release: "1"
  # CAN BE CHANGED: Must match the version number at the end of MODEL_URI.
  # Example: `"7"` when MODEL_URI ends with `/7`.
  MODEL_VERSION: "1"

  # The registered model name in MLflow. Usually stable across deployments.
  # Changes only if the production model area is renamed or a new model replaces
  # this one. In that case, the training-to-inference handoff guide must be
  # updated as well.
  # CAN BE CHANGED: Use your MLflow registered model name. Example:
  # `"fraud-risk-classifier-prod"`.
  MODEL_REGISTRY_NAME: "wine-quality-classifier-prod"

  # ─────────────────────────────────────────────────────────────────────────
  # MLflow connectivity — where the pod connects to download the model artifact
  # and (optionally) log prediction metadata.
  # ─────────────────────────────────────────────────────────────────────────

  # MLflow Tracking Server URI reachable from inside the Kubernetes cluster.
  #
  # LOCAL LAB option A — MLflow running on the learner's WSL2 host:
  #   Use host.docker.internal (Docker Desktop's magic hostname for the host).
  #   This works when the pod is running in a kind cluster on the same machine.
  #   MLFLOW_TRACKING_URI: "http://host.docker.internal:5000"
  #
  # LOCAL LAB option B — MLflow running as a Kubernetes Service in the cluster:
  #   Use the cluster-internal DNS name: mlflow-service.<namespace>.svc.cluster.local
  #   This is the correct enterprise pattern.
  #   MLFLOW_TRACKING_URI: "http://mlflow-service.ml-platform.svc.cluster.local:5000"
  #
  # ENTERPRISE EQUIVALENT: The MLflow server runs as a Kubernetes Deployment
  # behind a Service with TLS termination, authentication, and high availability.
  # The URI would be https://mlflow.internal.company.com.
  # CAN BE CHANGED: Point this at the MLflow Tracking Server reachable from the
  # pod. Examples: `"http://host.docker.internal:5000"` for local WSL2, or
  # `"http://mlflow-service.ml-platform.svc.cluster.local:5000"` in-cluster.
  MLFLOW_TRACKING_URI: "http://host.docker.internal:5000"

  # ─────────────────────────────────────────────────────────────────────────
  # Application identity and observability — non-sensitive, rarely change.
  # ─────────────────────────────────────────────────────────────────────────

  # CAN BE CHANGED: Application name shown in logs and health responses.
  # Example: `"fraud-risk-inference-api"`.
  APP_NAME: "wine-quality-inference-api"

  # LOCAL SHORTCUT: local-kind identifies this as a local kind cluster deployment.
  # ENTERPRISE EQUIVALENT: staging, production, eu-west-1-production, etc.
  # CAN BE CHANGED: Use the environment name you want logs and metrics to show.
  # Examples: `"local-kind"`, `"staging"`, `"production"`.
  APP_ENVIRONMENT: "local-kind"

  # CAN BE CHANGED: Application/container release version displayed by the API.
  # Keep this aligned with the image tag in 05-inference-deployment.yaml.
  # Example: `"1.1.0"`.
  APP_VERSION: "1.0.0"

  # Log level for the inference API's structured JSON logger.
  # INFO is appropriate for production. DEBUG adds verbose model loading details,
  # useful when debugging artifact download failures.
  # CAN BE CHANGED: Use `"DEBUG"` temporarily for troubleshooting, then return
  # to `"INFO"` so production logs stay readable.
  LOG_LEVEL: "INFO"
