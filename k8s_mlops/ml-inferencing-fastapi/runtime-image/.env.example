# =============================================================================
# FILE:    .env.example
# PURPOSE: Local pre-container configuration for the FastAPI inference runtime.
# WHEN:    Use before building the container image to prove the approved MLflow
#          model can be loaded by the same application code Kubernetes will run.
# =============================================================================
#
# Copy this file to .env from WSL2:
#
#   cp .env.example .env
#
# Enterprise translation:
# - Local developer path: .env lets one engineer validate the runtime quickly.
# - Kubernetes path: these same names come from ConfigMap and Secret objects.
# - CI/CD path: a release pipeline renders the immutable MODEL_URI after model
#   approval in MLflow, then triggers a new Deployment rollout.
#
# Anti-pattern this avoids:
# - Do not maintain long manual "export ..." blocks in documentation. They are
#   easy to mistype, hard to audit, and drift away from Kubernetes manifests.

MODEL_REGISTRY_NAME=wine-quality-classifier-prod
MODEL_VERSION=1
MODEL_URI=models:/wine-quality-classifier-prod/1
MLFLOW_TRACKING_URI=http://127.0.0.1:5000

APP_NAME=wine-quality-inference-api
APP_ENVIRONMENT=local-pre-container
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# Kubernetes normally injects these values through the downward API. Local runs
# use clear placeholders so health responses still teach what the fields mean.
POD_NAME=local-fastapi-process
POD_NAMESPACE=local-dev
NODE_NAME=wsl2-localhost
